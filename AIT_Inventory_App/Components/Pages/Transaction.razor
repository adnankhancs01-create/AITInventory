    private async Task AddTransaction()
    {
        var getProducts = await _ProductService.GetProductsReportAsync(0, 1, int.MaxValue, string.Empty);
        var getClient = await _clientService.GetAllClientsAsync(0, 1, int.MaxValue, string.Empty);
        // var getProducts = await _ProductService.GetProductsAsync(0, 1, int.MaxValue, string.Empty);
        if (getProducts == null || (getProducts.Data.Item1 == null || getProducts.Data.Item1.Count == 0))
            await DialogService.Alert("No products found. Please add a product before adding stock.", "Error");

        await DialogService.OpenAsync<AddEditTransactionPopup>(
            "Add Transaction",
            new Dictionary<string, object>() {
                {"Transaction", new AddEditTransactionRequestModel() } ,
               { "Products",getProducts?.Data.Item1},
               { "Clients",getClient?.Data.Item1}

                    },
            new DialogOptions() { Width = "600px", Height = "auto" }
        );
        // After closing, refresh grid
        await LoadData(new LoadDataArgs() { Skip = 0, Top = 20 });
    }


