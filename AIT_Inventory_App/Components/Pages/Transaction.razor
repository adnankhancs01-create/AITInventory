@page "/Transaction"
@using Common.Models
@using Common.Models.RequestModel
@using Common.Models.ResponseModel
@using Service.IService
@inject ITransactionService _TransactionService
@inject IProductService _ProductService
@inject IClientService _clientService
@inject NavigationManager Navigation
@inject DialogService DialogService
@using AIT_Inventory_App.Components.Pupups


<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
    <h3 style="margin:0;">Transaction Management</h3>
    <RadzenButton Text="Add Transaction" Icon="add_circle" ButtonStyle="ButtonStyle.Primary"
                  Click="@AddTransaction" />
</div>


<RadzenDataGrid Data="@Transactions" TItem="GetTransactionResponseModel"
                Count="@count"
                LoadData="@LoadData"
                AllowPaging="true" PageSize="20"
                AllowSorting="false"
                AllowFiltering="true">

    <Columns>
        <RadzenDataGridColumn TItem="GetTransactionResponseModel" Property="ClientName" Title="Name" Filterable="true" />
        <RadzenDataGridColumn TItem="GetTransactionResponseModel" Property="ClientPhone" Title="Client Phone" Filterable="true" />
        <RadzenDataGridColumn TItem="GetTransactionResponseModel" Property="ClientAddress" Title="Client Address" Filterable="true" />
        <RadzenDataGridColumn TItem="GetTransactionResponseModel" Property="ProductName" Title="Product Name" Filterable="true" />
        <RadzenDataGridColumn TItem="GetTransactionResponseModel" Property="TransactionType" Title="Transaction Type" Filterable="true" />
        <RadzenDataGridColumn TItem="GetTransactionResponseModel" Property="Quantity" Title="Quantity" Filterable="true" />
        <RadzenDataGridColumn TItem="GetTransactionResponseModel" Property="TransactionDate" Title="Transaction Date" Filterable="true" />
        <RadzenDataGridColumn TItem="GetTransactionResponseModel" Property="TotalAmount" Title="Total Amount" Filterable="true" />
        <RadzenDataGridColumn TItem="GetTransactionResponseModel" Property="ClientAmount" Title="Client Amount" Filterable="true" />

        <RadzenDataGridColumn TItem="GetTransactionResponseModel" Title="Actions" Filterable="false">
            <Template Context="Transaction">
                <RadzenButton Text="" Icon="edit" Size="ButtonSize.Small"
                              Click="@(() => Edit(Transaction.Id))" Style="margin-right:5px" />
                <RadzenButton Text="" Icon="visibility" Size="ButtonSize.Small"
                              Click="@(() => ViewCategory(Transaction))" />
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    private IEnumerable<GetTransactionResponseModel>? Transactions;
    private int count;
    private async Task LoadData(LoadDataArgs args)
    {
        int pageIndex = (args.Skip ?? 0) / (args.Top ?? 10) + 1;
        int pageSize = args.Top ?? 10;

        var result = await _TransactionService.GetTransactionAsync(0, pageIndex, pageSize, args.Filter);
        if (result.Success)
        {
            Transactions = result.Data.Item1.ToList();
            count = result.Data.Item2;
        }
        else
        {
            Transactions = new List<GetTransactionResponseModel>();
            count = 0;
        }
    }

