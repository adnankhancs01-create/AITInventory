@using Common.Models

@code {
    [Parameter] public Dictionary<string, string> Obj { get; set; } = new();
}

<RadzenCard Style="
    margin:1rem;
    padding:0;
    border-radius:14px;
    box-shadow:0 6px 18px rgba(0,0,0,0.06);
    border:1px solid #f1f5f9;">

    <!-- Header -->
    <div style="
        padding:16px 20px;
        border-bottom:1px solid #f1f5f9;
        display:flex;
        justify-content:space-between;
        align-items:center;">

        <div style="font-weight:600; font-size:16px; color:#111827;">
            Details
        </div>

        <div style="font-size:12px; color:#9ca3af;">
            @Obj?.Count item(s)
        </div>
    </div>

    <!-- Content -->
    <div style="padding:8px 0;">

        @foreach (var property in Obj)
        {
            <div style="
                display:flex;
                padding:12px 20px;
                align-items:center;
                justify-content:space-between;
                border-bottom:1px solid #f9fafb;
                transition:background 0.2s ease;"
                 onmouseover="this.style.background='#f9fafb'"
                 onmouseout="this.style.background='transparent'">

                <!-- Key -->
                <div style="
                    width:35%;
                    font-size:13px;
                    font-weight:500;
                    color:#6b7280;">
                    @property.Key
                </div>

                <!-- Value -->
                <div style="
                    width:65%;
                    font-size:14px;
                    font-weight:500;
                    color:#111827;
                    text-align:right;
                    word-break:break-word;">
                    @(string.IsNullOrWhiteSpace(property.Value) ? "-" : property.Value)
                </div>

            </div>
        }

    </div>

</RadzenCard>